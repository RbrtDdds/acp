{
  "name": "@rbrtdds/acp-embeddings",
  "version": "0.1.2",
  "description": "AI Context Protocol — local embedding provider using transformers.js",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "ai",
    "embeddings",
    "transformers",
    "semantic-search",
    "huggingface"
  ],
  "author": "Robert Dudas",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/robodudas/acp.git",
    "directory": "packages/embeddings"
  },
  "homepage": "https://github.com/robodudas/acp#readme",
  "bugs": "https://github.com/robodudas/acp/issues",
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@rbrtdds/acp-core": "workspace:*",
    "@huggingface/transformers": "^3.4.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0"
  }
}
