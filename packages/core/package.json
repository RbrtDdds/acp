{
  "name": "@rbrtdds/acp-core",
  "version": "0.1.0",
  "description": "AI Context Protocol — core library for persistent AI memory",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": ["ai", "context", "memory", "claude", "llm", "mcp", "semantic-search"],
  "author": "Robert Dudas",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/robodudas/acp.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/robodudas/acp#readme",
  "bugs": "https://github.com/robodudas/acp/issues",
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "sql.js": "^1.11.0",
    "uuid": "^11.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "@types/uuid": "^10.0.0",
    "@types/node": "^22.0.0"
  }
}
