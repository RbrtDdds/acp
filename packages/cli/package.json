{
  "name": "@rbrtdds/acp-cli",
  "version": "0.1.2",
  "description": "AI Context Protocol — CLI tool for managing AI memory",
  "type": "module",
  "bin": {
    "acp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "ai",
    "context",
    "memory",
    "claude",
    "llm",
    "cli"
  ],
  "author": "Robert Dudas",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/robodudas/acp.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/robodudas/acp#readme",
  "bugs": "https://github.com/robodudas/acp/issues",
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@rbrtdds/acp-core": "workspace:*",
    "@rbrtdds/acp-embeddings": "workspace:*",
    "commander": "^13.1.0",
    "chalk": "^5.4.0",
    "ora": "^8.2.0",
    "inquirer": "^12.4.0"
  },
  "peerDependencies": {
    "better-sqlite3": ">=9.0.0"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "@types/inquirer": "^9.0.0"
  }
}
